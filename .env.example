# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DEEPSEEK_API_KEY: Required for DeepSeek LLM API calls.
# Add your DeepSeek API key in the AI Studio Secrets panel with the name DEEPSEEK_API_KEY,
# or create a .env file in the project root and add it there.
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# PREVIEW_DATA_DIR: Optional local persistence directory for Node preview backend.
# Relative paths are resolved from project root. Default is .data
PREVIEW_DATA_DIR=".data"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
